#######################################################################
# .env.production.example — PRODUCTION (placeholders only)
# Production secrets are NEVER in a file. They live in:
#   - GitHub Actions secrets (scoped to the `production` Environment)
#   - Supabase Edge secrets on the PRODUCTION project
#   - EAS credentials service (store signing/submission)
# This template documents which values production needs. See SECRETS_MATRIX.md.
#######################################################################

# ---- Mobile (public, production build profile) ----
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PROD_ANON_KEY
EXPO_PUBLIC_REVENUECAT_KEY=YOUR_REVENUECAT_PUBLIC_SDK_KEY
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/XXXX

# ---- Edge Functions runtime (supabase secrets set, prod project) ----
SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PROD_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_PROD_SERVICE_ROLE_KEY
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY
REVENUECAT_WEBHOOK_SECRET=YOUR_REVENUECAT_WEBHOOK_SECRET

# ---- CI/CD (GitHub Actions secrets, `production` Environment — reference only) ----
SUPABASE_ACCESS_TOKEN=sbp_YOUR_SUPABASE_CLI_ACCESS_TOKEN
SUPABASE_PROD_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN
