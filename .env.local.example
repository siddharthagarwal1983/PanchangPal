#######################################################################
# .env.local.example — LOCAL DEVELOPER machine (placeholders only)
# Copy to a local, git-ignored file. Real .env* files are gitignored.
# Client vars belong in apps/mobile/.env; server vars only if you run
# Edge Functions locally with `supabase functions serve`.
#######################################################################

#######################################
# Mobile app (public) — put these in apps/mobile/.env
#######################################
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_SUPABASE_ANON_KEY
# Optional locally:
EXPO_PUBLIC_REVENUECAT_KEY=
EXPO_PUBLIC_SENTRY_DSN=

#######################################
# Local Edge Functions (only if running functions locally)
#######################################
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=YOUR_LOCAL_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SUPABASE_SERVICE_ROLE_KEY
# Optional (leave empty to disable that function locally):
OPENAI_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

#######################################
# Local DB + tooling
#######################################
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
NODE_ENV=development
PORT=4173
