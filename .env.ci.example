#######################################################################
# .env.ci.example — CI (GitHub Actions) reference (placeholders only)
# CI does NOT read a committed .env. These are GitHub Actions secrets/vars.
# Set in GitHub → Settings → Secrets and variables → Actions.
#######################################################################

# ---- Secrets consumed by cd.yml / ota.yml ----
SUPABASE_ACCESS_TOKEN=sbp_YOUR_SUPABASE_CLI_ACCESS_TOKEN
SUPABASE_STAGING_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_STAGING_REF=YOUR_STAGING_PROJECT_REF
SUPABASE_PROD_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN

# ---- Non-secret CI runtime values (already set in ci.yml) ----
# NODE_VERSION and PNPM_VERSION are workflow `env:` values (20.11.0 / 9.6.0).
# db-tests uses an ephemeral local Postgres — not a real secret:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
