#######################################################################
# .env.staging.example — STAGING (placeholders only)
# Staging secrets are NOT stored in a file. They live in:
#   - GitHub Actions secrets (CI/CD)  → SUPABASE_STAGING_*, SUPABASE_ACCESS_TOKEN, EXPO_ACCESS_TOKEN
#   - Supabase Edge secrets (runtime) → SUPABASE_*, OPENAI_API_KEY, REVENUECAT_WEBHOOK_SECRET
# This template documents which values staging needs. See SECRETS_MATRIX.md.
#######################################################################

# ---- Mobile (public, staging build profile) ----
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY
EXPO_PUBLIC_REVENUECAT_KEY=YOUR_REVENUECAT_PUBLIC_SDK_KEY
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/XXXX

# ---- Edge Functions runtime (supabase secrets set, staging project) ----
SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY
REVENUECAT_WEBHOOK_SECRET=YOUR_REVENUECAT_WEBHOOK_SECRET

# ---- CI/CD (GitHub Actions secrets — reference only) ----
SUPABASE_ACCESS_TOKEN=sbp_YOUR_SUPABASE_CLI_ACCESS_TOKEN
SUPABASE_STAGING_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_STAGING_REF=YOUR_STAGING_PROJECT_REF
EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN
