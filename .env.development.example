#######################################################################
# .env.development.example — shared DEVELOPMENT environment (placeholders)
# A hosted dev Supabase project (not local). Secrets live in the Supabase
# Edge secrets store / your secret manager — this file documents shape only.
#######################################################################

# Mobile (public) → apps/mobile/.env for dev builds
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_DEV_ANON_KEY
EXPO_PUBLIC_REVENUECAT_KEY=YOUR_REVENUECAT_PUBLIC_SDK_KEY
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/XXXX

# Edge Functions (set via `supabase secrets set` on the dev project)
SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_DEV_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_DEV_SERVICE_ROLE_KEY
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY
REVENUECAT_WEBHOOK_SECRET=YOUR_REVENUECAT_WEBHOOK_SECRET

NODE_ENV=development
