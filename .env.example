#######################################################################
# PanchangPal — .env.example  (MASTER REFERENCE — placeholders only)
#
# Copy the block(s) you need into the right place. NEVER put real secrets
# in any committed file. See docs/devops/ENVIRONMENT_VARIABLES.md and
# docs/devops/SECRETS_MATRIX.md for scope, ownership, and where each value
# actually lives (GitHub secrets / Supabase Edge secrets / EAS / local).
#
#   - Client (EXPO_PUBLIC_*) → apps/mobile/.env  (public, baked into the app)
#   - Server (Edge Functions) → Supabase Edge secrets (NOT a local file in prod)
#   - CI/CD → GitHub → Settings → Secrets and variables → Actions
#
# This master file lists EVERY variable the repo actually uses, grouped by
# scope. The per-environment templates (.env.local/.staging/.production/.ci)
# contain the subset relevant to that environment.
#######################################################################


#######################################
# 1. Client / mobile (PUBLIC — EXPO_PUBLIC_*)
#    Read by apps/mobile/app.config.ts → expo-constants.
#    Public by design (embedded in the binary). No server secret here.
#######################################

# Supabase project the app talks to (RLS is the security boundary).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# RevenueCat public SDK key (subscription, F-4). Optional until billing is on.
EXPO_PUBLIC_REVENUECAT_KEY=YOUR_REVENUECAT_PUBLIC_SDK_KEY

# Sentry DSN for crash/error reporting. Optional in local dev.
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/XXXX


#######################################
# 2. Server / Edge Functions (SECRETS — Supabase Edge secrets)
#    Read via apps/backend/functions/_shared/env.ts (readEnv).
#    In prod/staging these are set with `supabase secrets set`, NOT a file.
#    A local .env here is only for running functions locally.
#######################################

# Required at boot for every function:
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY   # CRITICAL — bypasses RLS

# Optional — required only by the functions that use them:
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY                     # ask-guru, content-ingest
REVENUECAT_WEBHOOK_SECRET=YOUR_REVENUECAT_WEBHOOK_SECRET   # revenuecat-webhook


#######################################
# 3. CI/CD (GitHub Actions secrets)
#    Set in GitHub → Settings → Secrets and variables → Actions.
#    Listed here for reference ONLY — do not put these in a local .env.
#######################################

SUPABASE_ACCESS_TOKEN=sbp_YOUR_SUPABASE_CLI_ACCESS_TOKEN
SUPABASE_STAGING_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_STAGING_REF=YOUR_STAGING_PROJECT_REF
SUPABASE_PROD_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN


#######################################
# 4. Operational / local tooling (non-secret)
#######################################

# Target DB for scripts/migrate.sh and local pgTAP. Local default shown.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Standard Node mode. Usually set by the tool, not by you.
NODE_ENV=development

# Port for the local Command Center dashboard (scripts/command-center/serve.mjs).
PORT=4173


#######################################
# NOTE — NOT environment variables (do not add):
#   - Apple / Google store credentials → managed by EAS credentials service +
#     App Store Connect / Play Console (see docs/SETUP.md), not env vars.
#   - OPENAI_BASE, SUPABASE_FUNCTIONS_URL → a constant / a code comment, not env.
#######################################
